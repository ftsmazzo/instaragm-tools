# Postador — IA: a escolha de provedor e modelo é feita no PAINEL (seletor na tela Postador).
# As variáveis abaixo são opcionais e servem só de fallback quando o painel não envia (ex.: chamada direta à API).
# POSTADOR_IA_PROVIDER=openai
# POSTADOR_IA_MODEL_OPENAI=gpt-4o
# POSTADOR_IA_MODEL_CLAUDE=claude-sonnet-4-5-20250929

# Chaves de API (obrigatórias conforme o provedor que o cliente escolher no painel)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Imagen (Google) — para "Criar mídia com IA" com provedor Imagen (melhor qualidade para fotos)
# GEMINI_API_KEY=...

# Texto no carrossel com IA (Nano Banana / Imagen edit): defina POSTADOR_CAROUSEL_TEXTO_IA=gemini para usar
# Gemini/Imagen para inserir texto nas imagens; senão usa Sharp (overlay SVG). Modelo padrão: imagen-3.0-capability-001.
# POSTADOR_CAROUSEL_TEXTO_IA=gemini
# POSTADOR_CAROUSEL_TEXTO_IA_MODEL=imagen-3.0-capability-001

# Site de imóveis: dentro do EasyPanel a API não resolve o host público. Para "post por URL do imóvel" funcionar:
# SITE_IMOVEIS_PUBLIC_HOST=cmr-imobiliaria-site-imoveis.90qhxz.easypanel.host
# SITE_IMOVEIS_INTERNAL_ORIGIN=http://cmr-imobiliaria-site-imoveis:3000

# Armazenamento de mídia do Postador (escolha um):
# - cloudinary (padrão): Cloudinary. Imagens > ~9,5 MB são redimensionadas/comprimidas para caber no limite free (10 MB).
# - local: self-hosted na própria API (data/uploads). Exige POSTADOR_MEDIA_BASE_URL e volume em data/ para persistir.
# POSTADOR_STORAGE=cloudinary
# POSTADOR_MEDIA_BASE_URL=https://sua-api.90qhxz.easypanel.host

# Cloudinary — URLs públicas estáveis (como no workflow n8n). Se POSTADOR_STORAGE não for "local", Cloudinary tem prioridade sobre MinIO.
# Use o mesmo cloud e preset da automação (ex.: preset n8nimage).
# CLOUDINARY_CLOUD_NAME=dakky1ulv
# CLOUDINARY_UPLOAD_PRESET=n8nimage

# MinIO — armazenamento de mídia do Postador (usado se POSTADOR_STORAGE=cloudinary e Cloudinary não estiver configurado).
# Dentro do EasyPanel a API não resolve o host público (getaddrinfo EAI_AGAIN). Use:
#   MINIO_INTERNAL_URL = URL interna do serviço MinIO (conexão do container)
#   MINIO_PUBLIC_URL   = URL pública (para os links que o Instagram vai baixar)
MINIO_INTERNAL_URL=http://cmr-imobiliaria-minio:9000
MINIO_PUBLIC_URL=https://cmr-imobiliaria-minio.90qhxz.easypanel.host
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=...
MINIO_BUCKET=crm
# Os arquivos do Postador ficam em crm/postador/... Se não usar EasyPanel, pode usar só MINIO_SERVER_URL.

# Banco: se definido, config (Instagram, empresa) e cronograma são gravados no PostgreSQL (tabelas app_config e postador_cronograma). Sem volume no EasyPanel.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Webhook n8n para disparar a raspagem de postagens (obrigatório para o botão Raspar).
# No EasyPanel use a URL INTERNA do app n8n (a API não resolve o domínio público de dentro do container):
# N8N_WEBHOOK_RASPAR_POSTAGENS=http://NOME_DO_APP_N8N:5678/webhook/raspar_postagens
# Ex.: se o app se chama "fabricaia-n8n" e a porta é 5678:
# N8N_WEBHOOK_RASPAR_POSTAGENS=http://fabricaia-n8n:5678/webhook/raspar_postagens
N8N_WEBHOOK_RASPAR_POSTAGENS=https://fabricaia-n8n.90qhxz.easypanel.host/webhook/raspar_postagens
